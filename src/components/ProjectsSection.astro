---
import { Image } from "astro:assets";
import { Eye } from "@lucide/astro";
import { projects } from "@/data/projects.js";
---

<div>
  <h2 class="mb-5 text-lg font-semibold tracking-tight text-foreground">Projects</h2>

  <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
    {
      projects.map((project) => (
        <a
          class="group block relative overflow-hidden rounded-lg"
          href={project.id}
          rel="noopener noreferrer"
          title={project.title}
          transition:name={project.id}
        >
          <Image
            class="w-full aspect-[4/3] object-cover rounded-lg object-top"
            src={project.src}
            alt={project.alt}
            loading="lazy"
            fetchpriority="low"
            width="720"
            height="540"
            decoding="async"
            format="webp"
          />
          <div class="mt-2 flex items-center justify-between">
            <span class="text-sm font-medium text-foreground truncate">{project.title}</span>
            <Eye class="size-3.5 text-muted-foreground opacity-0 group-hover:opacity-100 transition shrink-0" />
          </div>
        </a>
      ))
    }
  </div>
</div>

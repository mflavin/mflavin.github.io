---
import { Mail } from "@lucide/astro";
import { siteConfig } from "@/data/siteConfig";
import GithubSvg from "public/images/github.svg";
import LinkedinSvg from "public/images/linkedin.svg";
import DarkModeToggle from "@components/DarkModeToggle.astro";
---

<footer class="w-full max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 mt-10 sm:mt-14">
  <div
    class="py-6 border-t border-border flex flex-col sm:flex-row sm:justify-between items-center gap-y-4"
  >
    <p class="text-sm text-muted-foreground">
      &copy; {new Date().getFullYear()} {siteConfig.name}
    </p>

    <ul class="flex items-center gap-x-3">
      <li class="inline-block">
        <a
          class="btn btn-rounded"
          title="Send me an email"
          aria-label="Send me an email"
          href={siteConfig.social.email}
        >
          <span class="sr-only">Email</span>
          <Mail class="size-4" />
        </a>
      </li>
      <li class="inline-block">
        <a
          class="btn btn-rounded"
          title="My LinkedIn profile"
          aria-label="My LinkedIn profile"
          target="_blank"
          rel="noopener noreferrer"
          href={siteConfig.social.linkedin}
        >
          <span class="sr-only">LinkedIn</span>
          <LinkedinSvg class="size-4" />
        </a>
      </li>
      <li class="inline-block">
        <a
          class="btn btn-rounded"
          title="My GitHub profile"
          aria-label="My GitHub profile"
          target="_blank"
          rel="noopener noreferrer"
          href={siteConfig.social.github}
        >
          <span class="sr-only">GitHub</span>
          <GithubSvg class="size-4" />
        </a>
      </li>
      <li class="inline-block">
        <DarkModeToggle />
      </li>
    </ul>
  </div>
</footer>
